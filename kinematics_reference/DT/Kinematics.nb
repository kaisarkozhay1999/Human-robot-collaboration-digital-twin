Cell[BoxData[{
 RowBox[{"ClearAll", "@", "jacobianCentered"}], "\n", 
 RowBox[{
  RowBox[{"jacobianCentered", "[", 
   RowBox[{
   "\[Theta]1_", ",", " ", "\[Theta]2_", ",", " ", "\[Theta]3_", ",", " ", 
    RowBox[{"h_", ":", " ", "0.01"}]}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"df1", ",", " ", "df2", ",", " ", "df3"}], "}"}], ",", "\n", 
    "  ", 
    RowBox[{
     RowBox[{"df1", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"forwardKinematics", "[", 
          RowBox[{
           RowBox[{"\[Theta]1", " ", "+", " ", "h"}], ",", " ", "\[Theta]2", ",",
            " ", "\[Theta]3"}], "]"}], " ", "-", "\n", "         ", 
         RowBox[{"forwardKinematics", "[", 
          RowBox[{
           RowBox[{"\[Theta]1", " ", "-", " ", "h"}], ",", " ", "\[Theta]2", ",",
            " ", "\[Theta]3"}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "h"}], ")"}]}]}], ";", "\n", "  ", 
     RowBox[{"df2", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", 
           RowBox[{"\[Theta]2", " ", "+", " ", "h"}], ",", " ", "\[Theta]3"}],
           "]"}], " ", "-", "\n", "         ", 
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", 
           RowBox[{"\[Theta]2", " ", "-", " ", "h"}], ",", " ", "\[Theta]3"}],
           "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "h"}], ")"}]}]}], ";", "\n", "  ", 
     RowBox[{"df3", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", 
           RowBox[{"\[Theta]3", " ", "+", " ", "h"}]}], "]"}], " ", "-", "\n",
          "         ", 
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", 
           RowBox[{"\[Theta]3", " ", "-", " ", "h"}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "h"}], ")"}]}]}], ";", "\n", "  ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"df1", ",", " ", "df2", ",", " ", "df3"}], "}"}], "]"}]}]}], 
   "\n", "]"}]}]}], "Code",
 CellChangeTimes->{{3.985850769028248*^9, 3.985850779857973*^9}},
 CellLabel->"In[52]:=",ExpressionUUID->"c06cd77d-133b-324b-8525-ae6b72a423ea"],

