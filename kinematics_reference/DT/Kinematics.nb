Cell[BoxData[{
 RowBox[{"ClearAll", "@", "jacobianForward"}], "\n", 
 RowBox[{
  RowBox[{"jacobianForward", "[", 
   RowBox[{
   "\[Theta]1_", ",", " ", "\[Theta]2_", ",", " ", "\[Theta]3_", ",", " ", 
    RowBox[{"h_", ":", " ", "0.01"}]}], "]"}], " ", ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"f0", ",", " ", "df1", ",", " ", "df2", ",", " ", "df3"}], "}"}],
     ",", "\n", "  ", 
    RowBox[{
     RowBox[{"f0", "  ", "=", " ", 
      RowBox[{"forwardKinematics", "[", 
       RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", "\[Theta]3"}], 
       "]"}]}], ";", "\n", "  ", 
     RowBox[{"df1", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"forwardKinematics", "[", 
          RowBox[{
           RowBox[{"\[Theta]1", " ", "+", " ", "h"}], ",", " ", "\[Theta]2", ",",
            " ", "\[Theta]3"}], "]"}], " ", "-", " ", "f0"}], ")"}], "/", 
       "h"}]}], ";", "\n", "  ", 
     RowBox[{"df2", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", 
           RowBox[{"\[Theta]2", " ", "+", " ", "h"}], ",", " ", "\[Theta]3"}],
           "]"}], " ", "-", " ", "f0"}], ")"}], "/", "h"}]}], ";", "\n", "  ", 
     RowBox[{"df3", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", 
           RowBox[{"\[Theta]3", " ", "+", " ", "h"}]}], "]"}], " ", "-", " ", 
         "f0"}], ")"}], "/", "h"}]}], ";", "\n", "  ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"df1", ",", " ", "df2", ",", " ", "df3"}], "}"}], "]"}]}]}], 
   "\n", "]"}]}]}], "Code",
 CellChangeTimes->{{3.9858495961878777`*^9, 3.9858496115661583`*^9}},
