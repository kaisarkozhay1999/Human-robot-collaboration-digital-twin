Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"ee0e3731-a3aa-9041-ab82-8d55296a0f65"],

Cell["\<\
The 3-DOF IK is the root of the vector-valued function

    f(\[Theta]1, \[Theta]2, \[Theta]3) = FK(\[Theta]1, \[Theta]2, \[Theta]3) \
- (xTarget, yTarget, \[CurlyPhi]Target)

Newton-Raphson for systems: linearise at the current guess, solve for the \
correction, update:

    {\[Theta]1, \[Theta]2, \[Theta]3}_{n+1} = {\[Theta]1, \[Theta]2, \
\[Theta]3}_n + \[Delta],   with   J \[CenterDot] \[Delta] = -f

The per-iteration cost is: (a) evaluate f via FK, (b) build J using centered \
finite differences (Topic 1), (c) solve J \[CenterDot] \[Delta] = -f via \
Gaussian elimination (Topic 2). All three course topics appear in each step.\
\>", "Text",
 CellChangeTimes->{
  3.9858546562866764`*^9},ExpressionUUID->"345f71fa-8169-254e-a971-\
ac386e2910ad"],

Cell[BoxData[{
 RowBox[{"ClearAll", "@", "newtonIKStep"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"newtonIKStep", "[", 
    RowBox[{
    "xTarget_", ",", " ", "yTarget_", ",", " ", "\[CurlyPhi]Target_"}], "]"}],
    "[", 
   RowBox[{"{", 
    RowBox[{"\[Theta]1_", ",", " ", "\[Theta]2_", ",", " ", "\[Theta]3_"}], 
    "}"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"f", ",", " ", "J", ",", " ", "augMat", ",", " ", "\[Delta]"}], 
     "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"f", " ", "=", " ", 
      RowBox[{
       RowBox[{"forwardKinematics", "[", 
        RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", "\[Theta]3"}], 
        "]"}], " ", "-", " ", 
       RowBox[{"{", 
        RowBox[{
        "xTarget", ",", " ", "yTarget", ",", " ", "\[CurlyPhi]Target"}], 
        "}"}]}]}], ";", "\n", "  ", 
     RowBox[{"J", " ", "=", " ", 
      RowBox[{"jacobianCentered", "[", 
       RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", "\[Theta]3"}], 
       "]"}]}], ";", "\n", "  ", 
     RowBox[{"augMat", " ", "=", " ", 
      RowBox[{"MapThread", "[", 
       RowBox[{"Append", ",", " ", 
        RowBox[{"{", 
         RowBox[{"J", ",", " ", 
          RowBox[{"-", "f"}]}], "}"}]}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"\[Delta]", " ", "=", " ", 
      RowBox[{"gaussianEliminationPartialPivoting", "[", "augMat", "]"}]}], ";",
      "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Theta]1", " ", "+", " ", 
        RowBox[{"\[Delta]", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", " ", 
       RowBox[{"\[Theta]2", " ", "+", " ", 
        RowBox[{"\[Delta]", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", " ", 
       RowBox[{"\[Theta]3", " ", "+", " ", 
        RowBox[{"\[Delta]", "[", 
         RowBox[{"[", "3", "]"}], "]"}]}]}], "}"}]}]}], "\n", "  ", 
   "]"}]}]}], "Code",
 CellChangeTimes->{{3.9858547137527237`*^9, 3.9858547406915855`*^9}, {
  3.9858548957968082`*^9, 3.9858549143939095`*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"ca28b911-8a2c-9f46-bb1c-f096a7bfc3e5"],

