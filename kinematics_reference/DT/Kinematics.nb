Cell[CellGroupData[{

Cell["Interactive IK (3-DOF)", "Section",
 GeneratedCell->False,
 CellAutoOverwrite->False,
 CellChangeTimes->{{3.9858554576431713`*^9, 3.9858554751049824`*^9}, {
   3.9858555243522663`*^9, 3.9858555270110264`*^9}, 3.9858556483093224`*^9, 
   3.9858558824152966`*^9},ExpressionUUID->"0e1e9ff1-7098-c445-b09c-\
0107c1f69aa1"],

Cell["\<\
Now we can drag the sliders to choose a target pose (xTarget, yTarget, \
\[CurlyPhi]Target) and an initial guess. The widget runs the full 3\[Times]3 \
Newton-Raphson IK, reports the solved angles and the residual norm, and draws \
the resulting arm configuration.\
\>", "Text",
 CellChangeTimes->{{3.985855895529793*^9, 
  3.985855900983227*^9}},ExpressionUUID->"3aac031e-1177-f341-8e51-\
409fbb40cefd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"alignCenter", "@", 
  RowBox[{"Manipulate", "[", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "target", ",", "res", ",", "\[Theta]1s", ",", "\[Theta]2s", ",", 
        "\[Theta]3s", ",", "fk", ",", "armPlot", ",", "errNorm"}], "}"}], ",", 
      RowBox[{
       RowBox[{"target", "=", 
        RowBox[{"{", 
         RowBox[{"xT", ",", "yT", ",", "\[CurlyPhi]T"}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"res", "=", 
        RowBox[{"inverseKinematics", "[", 
         RowBox[{
         "xT", ",", "yT", ",", "\[CurlyPhi]T", ",", "\[Theta]1g", ",", 
          "\[Theta]2g", ",", "\[Theta]3g", ",", "nIter"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Theta]1s", "=", 
        RowBox[{"res", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}]}], ";", 
       RowBox[{"\[Theta]2s", "=", 
        RowBox[{"res", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "2"}], "]"}], "]"}]}], ";", 
       RowBox[{"\[Theta]3s", "=", 
        RowBox[{"res", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "3"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fk", "=", 
        RowBox[{
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1s", ",", "\[Theta]2s", ",", "\[Theta]3s"}], "]"}],
          "//", "N"}]}], ";", "\[IndentingNewLine]", 
