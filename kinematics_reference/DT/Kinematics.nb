Cell[BoxData[{
 RowBox[{"ClearAll", "@", "jacobianCentered4"}], "\n", 
 RowBox[{
  RowBox[{"jacobianCentered4", "[", 
   RowBox[{
   "\[Theta]1_", ",", " ", "\[Theta]2_", ",", " ", "\[Theta]3_", ",", " ", 
    RowBox[{"h_", ":", " ", "0.01"}]}], "]"}], " ", ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"df1", ",", " ", "df2", ",", " ", "df3"}], "}"}], ",", "\n", 
    "  ", 
    RowBox[{
     RowBox[{"df1", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{
            RowBox[{"\[Theta]1", " ", "+", " ", 
             RowBox[{"2", " ", "h"}]}], ",", " ", "\[Theta]2", ",", " ", 
            "\[Theta]3"}], "]"}]}], " ", "+", "\n", "          ", 
         RowBox[{"8", " ", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{
            RowBox[{"\[Theta]1", " ", "+", " ", "h"}], ",", " ", "\[Theta]2", 
            ",", " ", "\[Theta]3"}], "]"}]}], " ", "-", "\n", "          ", 
         RowBox[{"8", " ", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{
            RowBox[{"\[Theta]1", " ", "-", " ", "h"}], ",", " ", "\[Theta]2", 
            ",", " ", "\[Theta]3"}], "]"}]}], " ", "+", "\n", "          ", 
         RowBox[{"forwardKinematics", "[", 
          RowBox[{
           RowBox[{"\[Theta]1", " ", "-", " ", 
            RowBox[{"2", " ", "h"}]}], ",", " ", "\[Theta]2", ",", " ", 
           "\[Theta]3"}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"12", " ", "h"}], ")"}]}]}], ";", "\n", "  ", 
     RowBox[{"df2", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{"\[Theta]1", ",", " ", 
            RowBox[{"\[Theta]2", " ", "+", " ", 
             RowBox[{"2", " ", "h"}]}], ",", " ", "\[Theta]3"}], "]"}]}], " ",
          "+", "\n", "          ", 
         RowBox[{"8", " ", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{"\[Theta]1", ",", " ", 
            RowBox[{"\[Theta]2", " ", "+", " ", "h"}], ",", " ", 
            "\[Theta]3"}], "]"}]}], " ", "-", "\n", "          ", 
         RowBox[{"8", " ", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{"\[Theta]1", ",", " ", 
            RowBox[{"\[Theta]2", " ", "-", " ", "h"}], ",", " ", 
            "\[Theta]3"}], "]"}]}], " ", "+", "\n", "          ", 
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", 
           RowBox[{"\[Theta]2", " ", "-", " ", 
            RowBox[{"2", " ", "h"}]}], ",", " ", "\[Theta]3"}], "]"}]}], 
        ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"12", " ", "h"}], ")"}]}]}], ";", "\n", "  ", 
     RowBox[{"df3", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", 
            RowBox[{"\[Theta]3", " ", "+", " ", 
             RowBox[{"2", " ", "h"}]}]}], "]"}]}], " ", "+", "\n", 
         "          ", 
         RowBox[{"8", " ", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", 
            RowBox[{"\[Theta]3", " ", "+", " ", "h"}]}], "]"}]}], " ", "-", 
         "\n", "          ", 
         RowBox[{"8", " ", 
          RowBox[{"forwardKinematics", "[", 
           RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", 
            RowBox[{"\[Theta]3", " ", "-", " ", "h"}]}], "]"}]}], " ", "+", 
         "\n", "          ", 
         RowBox[{"forwardKinematics", "[", 
          RowBox[{"\[Theta]1", ",", " ", "\[Theta]2", ",", " ", 
           RowBox[{"\[Theta]3", " ", "-", " ", 
            RowBox[{"2", " ", "h"}]}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"12", " ", "h"}], ")"}]}]}], ";", "\n", "  ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"df1", ",", " ", "df2", ",", " ", "df3"}], "}"}], "]"}]}]}], 
   "\n", "]"}]}]}], "Code",
