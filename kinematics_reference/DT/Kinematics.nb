Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "259.7503095668132`"}], ",", "530.4320137138392`", ",", 
   "150.`"}], "}"}]], "Output",
 CellChangeTimes->{{3.985847528608423*^9, 3.9858475533768997`*^9}, 
   3.9858476609414444`*^9, 3.985847700483244*^9, 3.9858573868579063`*^9, 
   3.985857539788845*^9, 3.985911833557398*^9, 3.9859125596079826`*^9, 
