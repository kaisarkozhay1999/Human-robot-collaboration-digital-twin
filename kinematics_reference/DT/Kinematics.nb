 CellLabel->"Out[36]=",ExpressionUUID->"ec3663b9-db48-6643-a80a-a6dfc29a8264"]
}, Open  ]],

Cell["\<\
Expected output is a 3-element list {x, y, \[CurlyPhi]}. The first two \
entries are positions in mm, the third is the orientation in degrees, which \
equals 100+20+30=150.\
\>", "Text",
 CellChangeTimes->{
  3.9858475584002743`*^9, {3.9858477066435223`*^9, 
   3.9858477157842903`*^9}},ExpressionUUID->"231f8297-a75b-0d43-b170-\
88ab472151d6"]
}, Open  ]],

