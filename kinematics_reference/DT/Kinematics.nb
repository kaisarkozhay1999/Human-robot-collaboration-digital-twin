Cell["Arm Visualization", "Subsubsection",
 CellChangeTimes->{{3.9858475635180855`*^9, 
  3.985847564439516*^9}},ExpressionUUID->"c2167d69-b98d-2248-9d10-\
216031a3e2c4"],

Cell[BoxData[{
 RowBox[{"ClearAll", "@", "plotArm"}], "\n", 
 RowBox[{
  RowBox[{"plotArm", "[", 
   RowBox[{"\[Theta]1_", ",", " ", "\[Theta]2_", ",", " ", "\[Theta]3_"}], 
   "]"}], " ", ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "p0", ",", " ", "p1", ",", " ", "p2", ",", " ", "p3", ",", " ", "t1", ",",
       " ", "t2", ",", " ", "t3"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"t1", " ", "=", " ", 
      RowBox[{"\[Theta]1", " ", "Degree"}]}], ";", " ", 
     RowBox[{"t2", " ", "=", " ", 
      RowBox[{"\[Theta]2", " ", "Degree"}]}], ";", " ", 
     RowBox[{"t3", " ", "=", " ", 
      RowBox[{"\[Theta]3", " ", "Degree"}]}], ";", "\n", "  ", 
     RowBox[{"p0", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0"}], "}"}]}], ";", "\n", "  ", 
     RowBox[{"p1", " ", "=", " ", 
      RowBox[{"p0", " ", "+", " ", 
       RowBox[{"L1", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", "t1", "]"}], ",", " ", 
          RowBox[{"Sin", "[", "t1", "]"}]}], "}"}]}]}]}], ";", "\n", "  ", 
     RowBox[{"p2", " ", "=", " ", 
      RowBox[{"p1", " ", "+", " ", 
       RowBox[{"L2", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"t1", " ", "+", " ", "t2"}], "]"}], ",", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"t1", " ", "+", " ", "t2"}], "]"}]}], "}"}]}]}]}], ";", 
     "\n", "  ", 
     RowBox[{"p3", " ", "=", " ", 
      RowBox[{"p2", " ", "+", " ", 
       RowBox[{"L3", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"t1", " ", "+", " ", "t2", " ", "+", " ", "t3"}], "]"}], ",",
           " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"t1", " ", "+", " ", "t2", " ", "+", " ", "t3"}], "]"}]}], 
         "}"}]}]}]}], ";", "\n", "  ", 
     RowBox[{"Graphics", "[", 
      RowBox[{
       RowBox[{"{", "\n", "    ", 
        RowBox[{"Thick", ",", " ", "Blue", ",", " ", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{"p0", ",", " ", "p1", ",", " ", "p2", ",", " ", "p3"}], 
           "}"}], "]"}], ",", "\n", "    ", "Red", ",", " ", 
         RowBox[{"PointSize", "[", "Large", "]"}], ",", " ", 
         RowBox[{"Point", "[", 
          RowBox[{"{", 
           RowBox[{"p0", ",", " ", "p1", ",", " ", "p2", ",", " ", "p3"}], 
           "}"}], "]"}], ",", "\n", "    ", "Black", ",", " ", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<Base\>\"", ",", " ", "p0", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "1.5"}], "}"}]}], "]"}], ",", "\n", "    ", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<Shoulder\>\"", ",", " ", "p1", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "1.5"}], "}"}]}], "]"}], ",", "\n", "    ", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<Elbow\>\"", ",", " ", "p2", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "1.5"}], "}"}]}], "]"}], ",", "\n", "    ", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<End-Effector\>\"", ",", " ", "p3", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", "1.5"}], "}"}]}], "]"}]}], "\n", "   ", 
        "}"}], ",", "\n", "   ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", " ", 
       RowBox[{"Axes", " ", "->", " ", "True"}], ",", "\n", "   ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "700"}], ",", " ", "700"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "700"}], ",", " ", "700"}], "}"}]}], "}"}]}], ",", 
       "\n", "   ", 
       RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "   ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<x (mm)\>\"", ",", " ", "\"\<y (mm)\>\""}], "}"}]}]}], 
      "]"}]}]}], "\n", "]"}]}]}], "Code",
 CellChangeTimes->{{3.9858475780884857`*^9, 3.985847584580921*^9}, {
  3.985848635774925*^9, 3.9858486664786205`*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"8e44c04c-4025-d243-ac87-887c4a60688d"]
