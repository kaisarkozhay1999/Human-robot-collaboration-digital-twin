Cell[CellGroupData[{

Cell["\<\
Topic 2: Linear Algebra (Gaussian Elimination, 3\[Times]3) & Topic 3 : Newton \
- Raphson for the 3x3 System\
\>", "Section",
 CellChangeTimes->{{3.985852869369631*^9, 3.985852869746483*^9}, {
  3.9859124774066486`*^9, 
  3.985912481186741*^9}},ExpressionUUID->"e8be16fe-0bee-e241-94c0-\
1a093114b3b3"],

Cell["\<\
Each Newton - Raphson step requires solving the linear system

    J \[CenterDot] \[Delta] = -f

where J is the 3x3 Jacobian, f the 3 - component residual vector, and \
\[Delta] the angle correction . We implement Gaussian elimination with \
partial pivoting .\
\>", "Text",
 CellChangeTimes->{{3.9858528938858223`*^9, 
  3.9858529136117363`*^9}},ExpressionUUID->"ac110b2f-0781-e946-af0f-\
76a780a1f3a0"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "gaussianEliminationPartialPivoting", "]"}], "\n", 
 RowBox[{
  RowBox[{"gaussianEliminationPartialPivoting", "[", "augMatr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "n", ",", "i", ",", "j", ",", "k", ",", "factor", ",", "x", ",", 
      "maxRow", ",", "temp", ",", 
      RowBox[{"Atemp", "=", 
       RowBox[{"augMatr", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"1", ";;", 
           RowBox[{"-", "2"}]}]}], "]"}], "]"}]}], ",", 
      RowBox[{"btemp", "=", 
       RowBox[{"augMatr", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"-", "1"}]}], "]"}], "]"}]}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "btemp", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Forward", " ", "elimination", " ", "with", " ", "partial", " ", 
       "pivoting"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
       RowBox[{"k", "<=", 
        RowBox[{"n", "-", "1"}]}], ",", 
       RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Partial", " ", 
         RowBox[{"pivoting", ":", 
          RowBox[{
          "Find", " ", "row", " ", "with", " ", "largest", " ", "absolute", " ",
            "value", " ", "in", " ", "column", " ", "k"}]}]}], "*)"}], 
       RowBox[{
        RowBox[{"maxRow", "=", 
         RowBox[{
          RowBox[{"First", "@", 
           RowBox[{"Ordering", "[", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Atemp", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"k", ";;"}], ",", "k"}], "]"}], "]"}], "]"}], ",", 
             RowBox[{"-", "1"}]}], "]"}]}], "+", "k", "-", "1"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Swap", " ", "rows", " ", "if", " ", "necessary"}], "*)"}], 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"maxRow", "!=", "k"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Atemp", "[", 
               RowBox[{"[", "k", "]"}], "]"}], ",", 
              RowBox[{"Atemp", "[", 
               RowBox[{"[", "maxRow", "]"}], "]"}]}], "}"}], "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Atemp", "[", 
               RowBox[{"[", "maxRow", "]"}], "]"}], ",", 
              RowBox[{"Atemp", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"btemp", "[", 
               RowBox[{"[", "k", "]"}], "]"}], ",", 
              RowBox[{"btemp", "[", 
               RowBox[{"[", "maxRow", "]"}], "]"}]}], "}"}], "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"btemp", "[", 
               RowBox[{"[", "maxRow", "]"}], "]"}], ",", 
              RowBox[{"btemp", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}], "}"}]}], ";"}]}], "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Perform", " ", "elimination", " ", "to", " ", "make", " ", "the", " ",
           "pivot", " ", "element", " ", "1", " ", "and", " ", "eliminate", " ",
           "the", " ", "column"}], "*)"}], 
        RowBox[{"factor", "=", 
         RowBox[{"Atemp", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "k"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"factor", "!=", "0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Atemp", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"Atemp", "[", 
              RowBox[{"[", "k", "]"}], "]"}], "/", "factor"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"btemp", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"btemp", "[", 
              RowBox[{"[", "k", "]"}], "]"}], "/", "factor"}]}], ";"}]}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Eliminate", " ", "the", " ", "k"}], "-", 
          RowBox[{
          "th", " ", "column", " ", "in", " ", "all", " ", "other", " ", 
           "rows"}]}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", 
           RowBox[{"k", "+", "1"}]}], ",", 
          RowBox[{"i", "<=", "n"}], ",", 
          RowBox[{"i", "++"}], ",", 
          RowBox[{
           RowBox[{"factor", "=", 
            RowBox[{"Atemp", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "k"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Atemp", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"Atemp", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "-", 
             RowBox[{"factor", "*", 
              RowBox[{"Atemp", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"btemp", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"btemp", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "-", 
             RowBox[{"factor", "*", 
              RowBox[{"btemp", "[", 
               RowBox[{"[", "k", "]"}], "]"}]}]}]}], ";"}]}], "]"}], ";"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Back", " ", "substitution"}], "*)"}], 
     RowBox[{"x", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "n", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"[", "n", "]"}], "]"}], "=", 
      RowBox[{
       RowBox[{"btemp", "[", 
        RowBox[{"[", "n", "]"}], "]"}], "/", 
       RowBox[{"Atemp", "[", 
        RowBox[{"[", 
         RowBox[{"n", ",", "n"}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", 
        RowBox[{"n", "-", "1"}]}], ",", 
       RowBox[{"i", ">=", "1"}], ",", 
       RowBox[{"i", "--"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"btemp", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "-", 
            RowBox[{"Total", "[", 
             RowBox[{
              RowBox[{"Atemp", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", 
                 RowBox[{
                  RowBox[{"i", "+", "1"}], ";;", "n"}]}], "]"}], "]"}], "*", 
              RowBox[{"x", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"i", "+", "1"}], ";;", "n"}], "]"}], "]"}]}], 
             "]"}]}], ")"}], "/", 
          RowBox[{"Atemp", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "i"}], "]"}], "]"}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Return", " ", "the", " ", "solution", " ", "vector"}], "*)"}], 
     "x"}]}], "]"}]}]}], "Code",
 CellChangeTimes->{3.985851603699953*^9, 3.9858528639537163`*^9, 
  3.98585297771196*^9},
 CellLabel->"In[71]:=",ExpressionUUID->"04685b31-031b-974d-8e98-616daa3bb1b4"]
