Cell[BoxData[{
 RowBox[{"ClearAll", "[", "inverseKinematics", "]"}], "\n", 
 RowBox[{
  RowBox[{"inverseKinematics", "[", 
   RowBox[{
   "xTarget_", ",", "yTarget_", ",", "\[CurlyPhi]Target_", ",", 
    "\[Theta]1init_", ",", "\[Theta]2init_", ",", "\[Theta]3init_", ",", 
    "maxIter_"}], "]"}], ":=", 
  RowBox[{"NestList", "[", 
   RowBox[{
    RowBox[{"newtonIKStep", "[", 
     RowBox[{"xTarget", ",", "yTarget", ",", "\[CurlyPhi]Target"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]1init", ",", "\[Theta]2init", ",", "\[Theta]3init"}], 
     "}"}], ",", "maxIter"}], "]"}]}]}], "Code",
