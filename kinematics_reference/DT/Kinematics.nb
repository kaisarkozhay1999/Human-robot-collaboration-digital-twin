The forward kinematics function takes the three joint angles (in degrees) and \
returns a 3-component pose: the (x, y) position of the end-effector in mm, \
plus the orientation \[CurlyPhi] (in degrees). Position uses standard \
trigonometry for a serial 3-link arm; orientation is simply the sum of joint \
angles because each joint rotates the next link relative to the previous.\
\>", "Text",
 CellChangeTimes->{
  3.985847122193119*^9},ExpressionUUID->"9af88399-30b4-5647-a8be-\
686dd393a2a3"],

Cell[BoxData[{
 RowBox[{"ClearAll", "@", "forwardKinematics"}], "\n", 
 RowBox[{
  RowBox[{"forwardKinematics", "[", 
   RowBox[{"\[Theta]1_", ",", " ", "\[Theta]2_", ",", " ", "\[Theta]3_"}], 
   "]"}], " ", ":=", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"L1", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]1", " ", "Degree"}], "]"}]}], " ", "+", " ", 
     RowBox[{"L2", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Theta]1", " ", "+", " ", "\[Theta]2"}], ")"}], " ", 
        "Degree"}], "]"}]}], " ", "+", 
     RowBox[{"L3", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
         "\[Theta]1", " ", "+", " ", "\[Theta]2", " ", "+", " ", 
          "\[Theta]3"}], ")"}], " ", "Degree"}], "]"}]}]}], ",", 
    RowBox[{
     RowBox[{"L1", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]1", " ", "Degree"}], "]"}]}], " ", "+", " ", 
     RowBox[{"L2", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Theta]1", " ", "+", " ", "\[Theta]2"}], ")"}], " ", 
        "Degree"}], "]"}]}], " ", "+", 
     RowBox[{"L3", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
         "\[Theta]1", " ", "+", " ", "\[Theta]2", " ", "+", " ", 
          "\[Theta]3"}], ")"}], " ", "Degree"}], "]"}]}]}], ",", 
    RowBox[{
    "\[Theta]1", " ", "+", " ", "\[Theta]2", " ", "+", " ", "\[Theta]3"}]}], 
   "}"}]}]}], "Code",
 CellChangeTimes->{
  3.985847147774143*^9, {3.985847546537426*^9, 3.9858475509097614`*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"7aa36ea4-7487-7246-930e-a20de09d8258"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"forwardKinematics", "[", 
   RowBox[{"100", ",", "20", ",", "30"}], "]"}], "//", "N"}]], "Input",
 CellChangeTimes->{
